{
  "info": {
    "name": "Open Brewery API QA",
    "_postman_id": "12345678-1234-1234-1234-123456789012",
    "description": "API automation tests using Open Brewery DB",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Breweries",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/breweries?per_page=3",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "breweries"
          ],
          "query": [
            {
              "key": "per_page",
              "value": "3"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response time is below 2000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Response contains 3 breweries', function () {",
              "    pm.expect(json.length).to.eql(3);",
              "});",
              "",
              "pm.test('First brewery has required fields', function () {",
              "    pm.expect(json[0]).to.have.property('id');",
              "    pm.expect(json[0]).to.have.property('name');",
              "    pm.expect(json[0]).to.have.property('country');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}